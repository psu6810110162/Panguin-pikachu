# Copy this to .env before running docker compose (or the server directly):
#   cp .env.example .env

# Default: SQLite inside the container/venv — nothing to configure.
DATABASE_URL=sqlite:///penguin_dash_server.db

# To use the Postgres profile instead (docker compose --profile postgres up),
# uncomment this line so `server` points at the `postgres` service instead of SQLite.
# Must use the psycopg3 dialect prefix (postgresql+psycopg://), not plain postgresql://.
# DATABASE_URL=postgresql+psycopg://penguin:penguin@postgres:5432/penguin_dash

# HMAC secret shared between the game client and the server (core/sync.py).
# Change this before deploying anywhere real — the default is dev-only.
SYNC_SECRET=dev-secret-change-me

# Port the dev server listens on.
PORT=5000

# Requests/window allowed per client IP on /api/v1/ (Flask-Limiter, in-memory store) —
# guards against a runaway client retry loop, not real DDoS protection (trusted-LAN assumption).
RATE_LIMIT=60 per minute
