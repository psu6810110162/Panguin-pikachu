#:kivy 2.1.0

<MenuScreen>:
    canvas.before:
        Rectangle:
            source: 'assets/Background/Purple Pixelated Motivational Quote Instagram Post.png'
            pos: self.pos
            size: self.size
    BoxLayout:
        orientation: 'vertical'
        padding: [40, 60, 40, 100]
        spacing: 16
        
        Label:
            text: 'Penguin Dash'
            font_name: 'assets/Component_UI/Font/Kenney Future.ttf'
            font_size: '64sp'
            bold: True
            size_hint_y: 0.25
            color: 1, 1, 1, 1
            outline_color: 0, 0, 0, 1
            outline_width: 2
            
        HoverButton:
            text: 'START GAME'
            font_name: 'assets/Component_UI/Font/Kenney Future.ttf'
            font_size: '22sp'
            size_hint: (0.7, 0.12)
            pos_hint: {'center_x': 0.5}
            background_normal: 'assets/Component_UI/PNG/Blue/Default/button_rectangle_depth_flat.png'
            background_down: 'assets/Component_UI/PNG/Blue/Default/button_rectangle_flat.png'
            border: (20, 20, 20, 20)
            color: 1, 1, 1, 1
            on_release: root.start_game()
            
        HoverButton:
            text: 'SHOP'
            font_name: 'assets/Component_UI/Font/Kenney Future.ttf'
            font_size: '20sp'
            size_hint: (0.7, 0.12)
            pos_hint: {'center_x': 0.5}
            background_normal: 'assets/Component_UI/PNG/Blue/Default/button_rectangle_depth_flat.png'
            background_down: 'assets/Component_UI/PNG/Blue/Default/button_rectangle_flat.png'
            border: (20, 20, 20, 20)
            color: 1, 1, 1, 1
            on_release: root.go_to_shop()
            
        HoverButton:
            text: 'HISTORY'
            font_name: 'assets/Component_UI/Font/Kenney Future.ttf'
            font_size: '20sp'
            size_hint: (0.7, 0.12)
            pos_hint: {'center_x': 0.5}
            background_normal: 'assets/Component_UI/PNG/Blue/Default/button_rectangle_depth_flat.png'
            background_down: 'assets/Component_UI/PNG/Blue/Default/button_rectangle_flat.png'
            border: (20, 20, 20, 20)
            color: 1, 1, 1, 1
            on_release: root.go_to_history()
        
 
    HoverButton:
        text: 'EXIT'
        font_name: 'assets/Component_UI/Font/Kenney Future.ttf'
        font_size: '20sp'
        size_hint: (None, None)
        size: (120, 50)
        pos_hint: {'center_x': 0.03, 'center_y': 0.03}
        background_normal: 'assets/Component_UI/PNG/Blue/Default/button_rectangle_depth_flat.png'
        background_down: 'assets/Component_UI/PNG/Blue/Default/button_rectangle_flat.png'
        border: (20, 20, 20, 20)
        color: 1, 1, 1, 1
        on_release: root.exit_game()
        
    HoverButton:
        id: sound_btn
        background_normal: 'assets/Component_UI/Button Sounds/volume_up.png'
        background_down: 'assets/Component_UI/Button Sounds/volume_down.png'
        background_color: (1, 1, 1, 1)
        border: (0, 0, 0, 0)
        size_hint: (None, None)
        size: (80, 80)
        pos_hint: {'center_x': 0.97, 'center_y': 0.03}
        on_release: root.toggle_sound()


            
<GamePlayScreen>:
    canvas.before:
        Rectangle:
            source: 'assets/Background/Purple Pixelated Motivational Quote Instagram Post.png'
            pos: self.pos
            size: self.size
    # เนื้อหาเดิมของ Gameplay จะถูกย้ายมาที่นี่ในภายหลังถ้าย้ายออกจาก python

<GameOverScreen>:
    canvas.before:
        # Semi-transparent dark overlay for background
        Color:
            rgba: 0, 0, 0, 0.7
        Rectangle:
            pos: self.pos
            size: self.size
            
    BoxLayout:
        orientation: 'vertical'
        padding: [50, 100, 50, 100]
        spacing: 30
        
        # Glass Panel
        RelativeLayout:
            size_hint: (1, 1)
            canvas.before:
                Color:
                    rgba: 1, 1, 1, 0.1  # Glass transparency
                RoundedRectangle:
                    pos: 0, 0
                    size: self.size
                    radius: [20,]
                Color:
                    rgba: 1, 1, 1, 0.2  # Glass border
                Line:
                    rounded_rectangle: (0, 0, self.width, self.height, 20)
                    width: 1.2

            BoxLayout:
                orientation: 'vertical'
                padding: [20, 40, 20, 40]
                spacing: 20
                
                Label:
                    text: 'GAME OVER'
                    font_name: 'assets/Component_UI/Font/Kenney Future.ttf'
                    font_size: '56sp'
                    bold: True
                    color: 1, 0.3, 0.3, 1
                    outline_color: 0, 0, 0, 1
                    outline_width: 2
                    size_hint_y: 0.25
                    
                Label:
                    id: score_label
                    font_name: 'assets/Component_UI/Font/Kenney Future.ttf'
                    text: 'DISTANCE: -- M'
                    font_size: '32sp'
                    color: 1, 1, 1, 0.9
                    size_hint_y: 0.15
                    
                TextInput:
                    id: name_input
                    font_name: 'assets/Component_UI/Font/Kenney Future.ttf'
                    hint_text: 'ENTER YOUR NAME'
                    font_size: '20sp'
                    multiline: False
                    size_hint: (0.8, 0.15)
                    pos_hint: {'center_x': 0.5}
                    background_color: 1, 1, 1, 0.05
                    foreground_color: 1, 1, 1, 1
                    cursor_color: 1, 1, 1, 1
                    hint_text_color: 1, 1, 1, 0.4
                    padding: [15, 10, 15, 10]
                    canvas.after:
                        Color:
                            rgba: 1, 1, 1, 0.2
                        Line:
                            rounded_rectangle: (self.x, self.y, self.width, self.height, 5)
                    
                HoverButton:
                    text: 'RETRY'
                    font_name: 'assets/Component_UI/Font/Kenney Future.ttf'
                    font_size: '28sp'
                    size_hint: (0.9, 0.2)
                    pos_hint: {'center_x': 0.5}
                    background_normal: 'assets/Component_UI/PNG/Blue/Default/button_rectangle_depth_gradient.png'
                    background_down: 'assets/Component_UI/PNG/Blue/Default/button_rectangle_gradient.png'
                    border: (10, 10, 10, 10)
                    on_release: root.retry_game()
                    
                BoxLayout:
                    orientation: 'horizontal'
                    size_hint: (0.9, 0.15)
                    pos_hint: {'center_x': 0.5}
                    spacing: 15
                    
                    HoverButton:
                        text: 'HISTORY'
                        font_name: 'assets/Component_UI/Font/Kenney Future.ttf'
                        font_size: '18sp'
                        background_normal: 'assets/Component_UI/PNG/Blue/Default/button_rectangle_depth_flat.png'
                        background_down: 'assets/Component_UI/PNG/Blue/Default/button_rectangle_flat.png'
                        border: (10, 10, 10, 10)
                        on_release: root.view_history()
                        
                    HoverButton:
                        text: 'HOME'
                        font_name: 'assets/Component_UI/Font/Kenney Future.ttf'
                        font_size: '18sp'
                        background_normal: 'assets/Component_UI/PNG/Blue/Default/button_rectangle_depth_flat.png'
                        background_down: 'assets/Component_UI/PNG/Blue/Default/button_rectangle_flat.png'
                        border: (10, 10, 10, 10)
                        on_release: root.go_home()
<HistoryScreen>:
    BoxLayout:
        orientation: 'vertical'
        padding: 50
        spacing: 20
        
        Label:
            font_name: 'assets/Component_UI/Font/Kenney Future.ttf'
            text: 'LEADERBOARD & HISTORY'
            font_size: '36sp'
            bold: True
            size_hint_y: 0.2
            
        ScrollView:
            size_hint_y: 0.6
            BoxLayout:
                orientation: 'vertical'
                size_hint_y: None
                height: self.minimum_height
                
                # Placeholder for History Rows
                Label:
                    font_name: 'assets/Component_UI/Font/Kenney Future.ttf'
                    text: '1. 24/02/2569: 120 m (5 Gems) 🏆'
                    font_size: '20sp'
                    size_hint_y: None
                    height: 50
                    
                Label:
                    font_name: 'assets/Component_UI/Font/Kenney Future.ttf'
                    text: '2. 24/02/2569: 80 m (3 Gems)'
                    font_size: '20sp'
                    size_hint_y: None
                    height: 50
                    
        HoverButton:
            font_name: 'assets/Component_UI/Font/Kenney Future.ttf'
            text: 'BACK'
            font_size: '20sp'
            size_hint: (0.6, 0.12)
            pos_hint: {'center_x': 0.5}
            background_normal: 'assets/Component_UI/PNG/Blue/Default/button_rectangle_depth_flat.png'
            background_down: 'assets/Component_UI/PNG/Blue/Default/button_rectangle_flat.png'
            border: (10, 10, 10, 10)
            on_release: root.go_back()

<ShopScreen>:
    BoxLayout:
        orientation: 'vertical'
        padding: 50
        spacing: 20
        
        BoxLayout:
            size_hint_y: 0.2
            Label:
                text: 'SHOP'
                font_size: '36sp'
                bold: True
                size_hint_x: 0.7
            Label:
                text: 'Gems: 💎 100' # ตัวอย่างใส่หลอกไว้ก่อน
                font_size: '24sp'
                color: 0.2, 0.8, 1, 1
                size_hint_x: 0.3
                
        ScrollView:
            size_hint_y: 0.6
            GridLayout:
                cols: 2
                spacing: 20
                size_hint_y: None
                height: self.minimum_height
                
                # ─── Skin 1: Ninja Frog ───
                BoxLayout:
                    orientation: 'vertical'
                    size_hint_y: None
                    height: 220
                    padding: 15
                    spacing: 12
                    canvas.before:
                        Color:
                            rgba: 0.2, 0.2, 0.3, 0.9
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [15,]
                    AnimatedSkin:
                        source: 'assets/pixelAdventure/Free/Main Characters/Ninja Frog/Idle (32x32).png'
                        size_hint_y: 0.5
                    Label:
                        text: 'NINJA FROG'
                        font_name: 'assets/Component_UI/Font/Kenney Future.ttf'
                        font_size: '14sp'
                        size_hint_y: 0.2
                    HoverButton:
                        text: 'EQUIP'
                        font_size: '14sp'
                        size_hint: (0.9, 0.25)
                        pos_hint: {'center_x': 0.5}
                        background_normal: 'assets/Component_UI/PNG/Blue/Default/button_rectangle_depth_gradient.png'
                        background_down: 'assets/Component_UI/PNG/Blue/Default/button_rectangle_gradient.png'
                        border: (10, 10, 10, 10)
                        on_release: root.buy_item('Ninja Frog')

                # ─── Skin 2: Mask Dude ───
                BoxLayout:
                    orientation: 'vertical'
                    size_hint_y: None
                    height: 220
                    padding: 15
                    spacing: 12
                    canvas.before:
                        Color:
                            rgba: 0.2, 0.2, 0.3, 0.9
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [15,]
                    AnimatedSkin:
                        source: 'assets/pixelAdventure/Free/Main Characters/Mask Dude/Idle (32x32).png'
                        size_hint_y: 0.5
                    Label:
                        text: 'MASK DUDE'
                        font_name: 'assets/Component_UI/Font/Kenney Future.ttf'
                        font_size: '14sp'
                        size_hint_y: 0.2
                    HoverButton:
                        text: 'EQUIP'
                        font_size: '14sp'
                        size_hint: (0.9, 0.25)
                        pos_hint: {'center_x': 0.5}
                        background_normal: 'assets/Component_UI/PNG/Blue/Default/button_rectangle_depth_gradient.png'
                        background_down: 'assets/Component_UI/PNG/Blue/Default/button_rectangle_gradient.png'
                        border: (10, 10, 10, 10)
                        on_release: root.buy_item('Mask Dude')

                # ─── Skin 3: Pink Man ───
                BoxLayout:
                    orientation: 'vertical'
                    size_hint_y: None
                    height: 220
                    padding: 15
                    spacing: 12
                    canvas.before:
                        Color:
                            rgba: 0.2, 0.2, 0.3, 0.9
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [15,]
                    AnimatedSkin:
                        source: 'assets/pixelAdventure/Free/Main Characters/Pink Man/Idle (32x32).png'
                        size_hint_y: 0.5
                    Label:
                        text: 'PINK MAN'
                        font_name: 'assets/Component_UI/Font/Kenney Future.ttf'
                        font_size: '14sp'
                        size_hint_y: 0.2
                    HoverButton:
                        text: 'EQUIP'
                        font_size: '14sp'
                        size_hint: (0.9, 0.25)
                        pos_hint: {'center_x': 0.5}
                        background_normal: 'assets/Component_UI/PNG/Blue/Default/button_rectangle_depth_gradient.png'
                        background_down: 'assets/Component_UI/PNG/Blue/Default/button_rectangle_gradient.png'
                        border: (10, 10, 10, 10)
                        on_release: root.buy_item('Pink Man')

                # ─── Skin 4: Virtual Guy ───
                BoxLayout:
                    orientation: 'vertical'
                    size_hint_y: None
                    height: 220
                    padding: 15
                    spacing: 12
                    canvas.before:
                        Color:
                            rgba: 0.2, 0.2, 0.3, 0.9
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [15,]
                    AnimatedSkin:
                        source: 'assets/pixelAdventure/Free/Main Characters/Virtual Guy/Idle (32x32).png'
                        size_hint_y: 0.5
                    Label:
                        text: 'VIRTUAL GUY'
                        font_name: 'assets/Component_UI/Font/Kenney Future.ttf'
                        font_size: '14sp'
                        size_hint_y: 0.2
                    HoverButton:
                        text: 'EQUIP'
                        font_size: '14sp'
                        size_hint: (0.9, 0.25)
                        pos_hint: {'center_x': 0.5}
                        background_normal: 'assets/Component_UI/PNG/Blue/Default/button_rectangle_depth_gradient.png'
                        background_down: 'assets/Component_UI/PNG/Blue/Default/button_rectangle_gradient.png'
                        border: (10, 10, 10, 10)
                        on_release: root.buy_item('Virtual Guy')
                        
        HoverButton:
            text: 'BACK'
            font_name: 'assets/Component_UI/Font/Kenney Future.ttf'
            font_size: '20sp'
            size_hint: (0.6, 0.12)
            pos_hint: {'center_x': 0.5}
            background_normal: 'assets/Component_UI/PNG/Blue/Default/button_rectangle_depth_flat.png'
            background_down: 'assets/Component_UI/PNG/Blue/Default/button_rectangle_flat.png'
            border: (10, 10, 10, 10)
            on_release: root.go_back()
