#:kivy 2.1.0

<MenuScreen>:
    canvas.before:
        Rectangle:
            source: 'assets/generated/background/gameplay_background_v1.png'
            pos: self.pos
            size: self.size

    BoxLayout:
        orientation: 'vertical'
        padding: [0, 50, 0, 50]
        spacing: 0

        # ── Title ──
        Label:
            text: 'Penguin Dash'
            font_name: 'assets/Component_UI/Font/Kenney Future.ttf'
            font_size: '64sp'
            bold: True
            size_hint_y: 0.25
            color: 1, 1, 1, 1
            outline_color: 0, 0, 0, 1
            outline_width: 2

        # ── Spacer ──
        Widget:
            size_hint_y: 0.08

        # ── Hero START GAME ──
        HoverButton:
            text: 'START GAME'
            font_name: 'assets/Component_UI/Font/Kenney Future.ttf'
            font_size: '32sp'
            size_hint: (0.45, 0.18)
            pos_hint: {'center_x': 0.5}
            background_normal: 'assets/Component_UI/PNG/Blue/Default/button_rectangle_depth_flat.png'
            background_down: 'assets/Component_UI/PNG/Blue/Default/button_rectangle_flat.png'
            border: (20, 20, 20, 20)
            color: 1, 1, 1, 1
            on_release: root.start_game()

        # ── Spacer ──
        Widget:
            size_hint_y: 0.12

        # ── Icon Row ──
        BoxLayout:
            orientation: 'horizontal'
            size_hint: (0.78, 0.22)
            pos_hint: {'center_x': 0.5}
            spacing: 0

            # HOW TO PLAY
            BoxLayout:
                orientation: 'vertical'
                spacing: 8
                HoverButton:
                    text: '?'
                    font_name: 'assets/Component_UI/Font/Kenney Future.ttf'
                    font_size: '44sp'
                    bold: True
                    size_hint: (None, None)
                    size: (90, 90)
                    pos_hint: {'center_x': 0.5}
                    background_normal: 'assets/Component_UI/PNG/Blue/Default/button_rectangle_depth_flat.png'
                    background_down: 'assets/Component_UI/PNG/Blue/Default/button_rectangle_flat.png'
                    background_color: (1, 1, 1, 1)
                    border: (20, 20, 20, 20)
                    on_release: root.show_how_to_play()
                Label:
                    text: 'HOW TO PLAY'
                    font_name: 'assets/Component_UI/Font/Kenney Future.ttf'
                    font_size: '14sp'
                    color: 1, 1, 1, 0.8
                    size_hint_y: None
                    height: 22
                    halign: 'center'

            # SHOP
            BoxLayout:
                orientation: 'vertical'
                spacing: 8
                HoverButton:
                    size_hint: (None, None)
                    size: (90, 90)
                    pos_hint: {'center_x': 0.5}
                    background_normal: 'assets/Component_UI/shop/medal_normal.png'
                    background_down: 'assets/Component_UI/shop/medal_normal.png'
                    background_color: (1, 1, 1, 1)
                    border: (0, 0, 0, 0)
                    on_release: root.go_to_shop()
                Label:
                    text: 'SHOP'
                    font_name: 'assets/Component_UI/Font/Kenney Future.ttf'
                    font_size: '14sp'
                    color: 1, 1, 1, 0.8
                    size_hint_y: None
                    height: 22
                    halign: 'center'

            # SOUND
            BoxLayout:
                orientation: 'vertical'
                spacing: 8
                HoverButton:
                    id: sound_btn
                    size_hint: (None, None)
                    size: (90, 90)
                    pos_hint: {'center_x': 0.5}
                    background_normal: 'assets/Component_UI/Button Sounds/volume_up.png'
                    background_down: 'assets/Component_UI/Button Sounds/volume_down.png'
                    background_color: (1, 1, 1, 1)
                    border: (0, 0, 0, 0)
                    on_release: root.toggle_sound()
                Label:
                    text: 'SOUND'
                    font_name: 'assets/Component_UI/Font/Kenney Future.ttf'
                    font_size: '14sp'
                    color: 1, 1, 1, 0.8
                    size_hint_y: None
                    height: 22
                    halign: 'center'

            # HISTORY
            BoxLayout:
                orientation: 'vertical'
                spacing: 8
                HoverButton:
                    size_hint: (None, None)
                    size: (90, 90)
                    pos_hint: {'center_x': 0.5}
                    background_normal: 'assets/Component_UI/history/trophy_normal.png'
                    background_down: 'assets/Component_UI/history/trophy_normal.png'
                    background_color: (1, 1, 1, 1)
                    border: (0, 0, 0, 0)
                    on_release: root.go_to_history()
                Label:
                    text: 'HISTORY'
                    font_name: 'assets/Component_UI/Font/Kenney Future.ttf'
                    font_size: '14sp'
                    color: 1, 1, 1, 0.8
                    size_hint_y: None
                    height: 22
                    halign: 'center'

        # ── Spacer ──
        Widget:
            size_hint_y: 0.08

        # ── EXIT (กลางล่าง) ──
        HoverButton:
            text: 'EXIT'
            font_name: 'assets/Component_UI/Font/Kenney Future.ttf'
            font_size: '18sp'
            size_hint: (0.2, 0.08)
            pos_hint: {'center_x': 0.5}
            background_normal: 'assets/Component_UI/PNG/Blue/Default/button_rectangle_depth_flat.png'
            background_down: 'assets/Component_UI/PNG/Blue/Default/button_rectangle_flat.png'
            border: (20, 20, 20, 20)
            color: 1, 1, 1, 1
            on_release: root.exit_game()


<GamePlayScreen>:
    canvas.before:
        Rectangle:
            source: 'assets/generated/background/gameplay_background_v1.png'
            pos: self.pos
            size: self.size
    # เนื้อหาเดิมของ Gameplay จะถูกย้ายมาที่นี่ในภายหลังถ้าย้ายออกจาก python

<GameOverScreen>:
    canvas.before:
        Rectangle:
            source: 'assets/generated/background/gameplay_background_v1.png'
            pos: self.pos
            size: self.size
        Color:
            rgba: 0.01, 0.03, 0.08, 0.78
        Rectangle:
            pos: self.pos
            size: self.size

    BoxLayout:
        orientation: 'vertical'
        padding: [50, 100, 50, 100]
        spacing: 30

        # Glass Panel
        RelativeLayout:
            size_hint: (1, 1)
            canvas.before:
                Color:
                    rgba: 1, 1, 1, 0.1  # Glass transparency
                RoundedRectangle:
                    pos: 0, 0
                    size: self.size
                    radius: [20,]
                Color:
                    rgba: 1, 1, 1, 0.2  # Glass border
                Line:
                    rounded_rectangle: (0, 0, self.width, self.height, 20)
                    width: 1.2

            BoxLayout:
                orientation: 'vertical'
                padding: [20, 40, 20, 40]
                spacing: 20

                Label:
                    text: 'GAME OVER'
                    font_name: 'assets/Component_UI/Font/Kenney Future.ttf'
                    font_size: '56sp'
                    bold: True
                    color: 1, 0.3, 0.3, 1
                    outline_color: 0, 0, 0, 1
                    outline_width: 2
                    size_hint_y: 0.25

                Label:
                    id: score_label
                    font_name: 'assets/Component_UI/Font/Kenney Future.ttf'
                    text: 'DISTANCE: -- M'
                    font_size: '32sp'
                    color: 1, 1, 1, 0.9
                    size_hint_y: 0.15

                TextInput:
                    id: name_input
                    font_name: 'assets/Component_UI/Font/Kenney Future.ttf'
                    hint_text: 'ENTER YOUR NAME'
                    font_size: '20sp'
                    multiline: False
                    size_hint: (0.8, 0.15)
                    pos_hint: {'center_x': 0.5}
                    background_color: 1, 1, 1, 0.05
                    foreground_color: 1, 1, 1, 1
                    cursor_color: 1, 1, 1, 1
                    hint_text_color: 1, 1, 1, 0.4
                    padding: [15, 10, 15, 10]
                    canvas.after:
                        Color:
                            rgba: 1, 1, 1, 0.2
                        Line:
                            rounded_rectangle: (self.x, self.y, self.width, self.height, 5)

                HoverButton:
                    text: 'RETRY'
                    font_name: 'assets/Component_UI/Font/Kenney Future.ttf'
                    font_size: '28sp'
                    size_hint: (0.9, 0.2)
                    pos_hint: {'center_x': 0.5}
                    background_normal: 'assets/Component_UI/PNG/Blue/Default/button_rectangle_depth_gradient.png'
                    background_down: 'assets/Component_UI/PNG/Blue/Default/button_rectangle_gradient.png'
                    border: (10, 10, 10, 10)
                    on_release: root.retry_game()

                BoxLayout:
                    orientation: 'horizontal'
                    size_hint: (0.9, 0.15)
                    pos_hint: {'center_x': 0.5}
                    spacing: 15

                    HoverButton:
                        text: 'HISTORY'
                        font_name: 'assets/Component_UI/Font/Kenney Future.ttf'
                        font_size: '18sp'
                        background_normal: 'assets/Component_UI/PNG/Blue/Default/button_rectangle_depth_flat.png'
                        background_down: 'assets/Component_UI/PNG/Blue/Default/button_rectangle_flat.png'
                        border: (10, 10, 10, 10)
                        on_release: root.view_history()

                    HoverButton:
                        text: 'HOME'
                        font_name: 'assets/Component_UI/Font/Kenney Future.ttf'
                        font_size: '18sp'
                        background_normal: 'assets/Component_UI/PNG/Blue/Default/button_rectangle_depth_flat.png'
                        background_down: 'assets/Component_UI/PNG/Blue/Default/button_rectangle_flat.png'
                        border: (10, 10, 10, 10)
                        on_release: root.go_home()
<HistoryScreen>:
    canvas.before:
        Rectangle:
            source: 'assets/generated/background/gameplay_background_v1.png'
            pos: self.pos
            size: self.size
        Color:
            rgba: 0.01, 0.03, 0.08, 0.72
        Rectangle:
            pos: self.pos
            size: self.size
    BoxLayout:
        orientation: 'vertical'
        padding: 50
        spacing: 20

        Label:
            font_name: 'assets/Component_UI/Font/Kenney Future.ttf'
            text: 'LEADERBOARD & HISTORY'
            font_size: '36sp'
            bold: True
            size_hint_y: 0.2

        ScrollView:
            size_hint_y: 0.6
            BoxLayout:
                id: history_list
                orientation: 'vertical'
                size_hint_y: None
                height: self.minimum_height
                # Rows are populated at runtime by HistoryScreen.load_history()
                # (called from on_enter) — no static placeholder rows here,
                # so there is nothing stale/emoji-bearing to flash before then.

        HoverButton:
            font_name: 'assets/Component_UI/Font/Kenney Future.ttf'
            text: 'BACK'
            font_size: '20sp'
            size_hint: (0.6, 0.12)
            pos_hint: {'center_x': 0.5}
            background_normal: 'assets/Component_UI/PNG/Blue/Default/button_rectangle_depth_flat.png'
            background_down: 'assets/Component_UI/PNG/Blue/Default/button_rectangle_flat.png'
            border: (10, 10, 10, 10)
            on_release: root.go_back()

<ShopScreen>:
    # Header/grid/cards/back-button are built responsively in screens/shop.py
    # from balance/v1/shop.json (core.shop_catalog) — a catalog change (add,
    # remove, reprice a skin) never touches this file. Only the static
    # full-screen background stays declarative here.
    canvas.before:
        Rectangle:
            source: 'assets/generated/background/gameplay_background_v1.png'
            pos: self.pos
            size: self.size
